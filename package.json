{
  "name": "plaintext-comments",
  "displayName": "Plain Text Comments",
  "description": "Support for toggling comments in plaintext files.",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.125.0"
  },
  "categories": [
    "Programming Languages"
  ],
  // Extends buitin "plaintext" language:  See [Syntax Highlight Guide | Visual Studio Code Extension API](https://code.visualstudio.com/api/language-extensions/syntax-highlight-guide#developing-a-new-grammar-extension)
  "contributes": {
    "grammars": [{
      "language": "plaintext", // Use the target language's information
      "scopeName": "text.plaintext.comments", // Must match the scopeName in the .tmLanguage.json file
      "path": "./syntaxes/plaintext.tmLanguage.json"
    }]
  }
}
